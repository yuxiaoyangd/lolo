# ── LLM（OpenAI-compatible Chat Completions API）────────────────────────────
# 必填。填写模型服务商签发的真实 API Key；不要把真实 Key 提交到 Git。
VOLCANO_API_KEY=your-api-key-here

# 可选，默认使用下面的火山方舟地址；必须是兼容 OpenAI API 的 Base URL。
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 可选，默认使用下面的模型；填写模型服务商提供的模型或推理接入点 ID。
VOLCANO_MODEL=deepseek-v4-flash-260425

# ── lolo 后端 ───────────────────────────────────────────────────────────────
# 可选，默认 3000。该端口提供 /chat、/approvals、/health 和 /health/mcp。
# 建议保留 3000，避免与 MCP 本地服务 3100、公网入口 3200 冲突。
LOLO_PORT=3000

# ── MCP Server ──────────────────────────────────────────────────────────────
# 可选，默认连接本机 3100；必须填写指向 /mcp 的完整 HTTP(S) URL。
# 本地示例：http://127.0.0.1:3100/mcp
# ngrok 示例：https://your-domain.ngrok-free.dev/mcp
MCP_URL=http://127.0.0.1:3100/mcp

# ── 调试日志 ────────────────────────────────────────────────────────────────
# 可选，默认关闭。开启值支持 true、1、yes、on（不区分大小写）。
# 开启后，浏览器 Console 会输出实际发送给 LLM 的 messages、tools 等完整请求。
# 日志可能包含对话、地址和订单信息，只建议在本地测试时开启。
LOLO_DEBUG_LLM=false
